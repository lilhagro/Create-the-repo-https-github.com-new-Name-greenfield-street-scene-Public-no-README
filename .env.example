# Environment template for Greenfield Street Scene
# Copy to .env and fill values. Never commit real secrets.

# SQLite local (default). For production, use Postgres:
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/greenfield?sslmode=require"
DATABASE_URL="file:./dev.db"

# Set false to force seed-data fallback even if DATABASE_URL exists
USE_DATABASE="true"

# Required by Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# Optional GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# App URL (Vercel sets this automatically in production)
# AUTH_URL="http://localhost:3000"
